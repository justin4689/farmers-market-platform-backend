            "url": { "raw": "{{base_url}}/api/admin/supervisors", "host": ["{{base_url}}"], "path": ["api", "admin", "supervisors"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Kone Supervisor\",\n  \"email\": \"kone.supervisor@xpertbot.com\",\n  \"password\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Requires admin token. Creates a supervisor account with `created_by` set to the authenticated admin."
