              "code": 201,
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"id\": 8,\n    \"name\": \"Diallo Operator\",\n    \"email\": \"diallo.operator@xpertbot.com\",\n    \"role\": \"operator\",\n    \"created_by\": 2,\n    \"created_at\": \"2026-04-28T15:00:00.000000Z\"\n  },\n  \"message\": \"Operator created successfully.\"\n}"
            }
          ]
        }
      ]
    },

    {
      "name": "Categories",
      "item": [
        {
          "name": "List Categories (tree)",
          "request": {
