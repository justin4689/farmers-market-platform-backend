    {
      "name": "Farmers",
      "item": [
        {
          "name": "Search Farmers",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/farmers/search?q=CI-2024",
              "host": ["{{base_url}}"],
              "path": ["api", "farmers", "search"],
              "query": [{ "key": "q", "value": "CI-2024", "description": "Search term — matches identifier or phone_number" }]
            },
            "description": "Search by farmer identifier (e.g. `CI-2024-001`) or phone number. Returns `total_outstanding_debt` for each result."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": [\n    {\n      \"id\": 1,\n      \"identifier\": \"CI-2024-001\",\n      \"firstname\": \"Konan\",\n      \"lastname\": \"Kouassi\",\n      \"phone_number\": \"+22507010001\",\n      \"credit_limit_fcfa\": 100000,\n      \"total_outstanding_debt\": 6400,\n      \"created_at\": \"2026-04-28T12:00:00.000000Z\"\n    }\n  ],\n  \"message\": \"Search results retrieved.\"\n}"
            },
            {
              "name": "422 — Missing query",
              "status": "Unprocessable Content",
              "code": 422,
              "body": "{\n  \"success\": false,\n  \"message\": \"Search query parameter \\\"q\\\" is required.\",\n  \"errors\": []\n}"
            }
          ]
        },
        {
          "name": "Show Farmer Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/farmers/1", "host": ["{{base_url}}"], "path": ["api", "farmers", "1"] },
            "description": "Returns the farmer profile including `total_outstanding_debt` (sum of all open/partial debt remaining_fcfa)."
          },
          "response": [
            {
              "name": "200 OK — Partial debt",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"id\": 1,\n    \"identifier\": \"CI-2024-001\",\n    \"firstname\": \"Konan\",\n    \"lastname\": \"Kouassi\",\n    \"phone_number\": \"+22507010001\",\n    \"credit_limit_fcfa\": 100000,\n    \"total_outstanding_debt\": 6400,\n    \"created_at\": \"2026-04-28T12:00:00.000000Z\"\n  },\n  \"message\": \"Farmer profile retrieved.\"\n}"
            },
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"success\": false,\n  \"message\": \"Farmer not found.\",\n  \"errors\": []\n}"
            }
          ]
        },
        {
          "name": "Create Farmer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/api/farmers", "host": ["{{base_url}}"], "path": ["api", "farmers"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"CI-2024-006\",\n  \"firstname\": \"Adjoumani\",\n  \"lastname\": \"Touré\",\n  \"phone_number\": \"+22507010006\",\n  \"credit_limit_fcfa\": 75000\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "`identifier` and `phone_number` must be unique. `credit_limit_fcfa` minimum is 0."
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"id\": 6,\n    \"identifier\": \"CI-2024-006\",\n    \"firstname\": \"Adjoumani\",\n    \"lastname\": \"Touré\",\n    \"phone_number\": \"+22507010006\",\n    \"credit_limit_fcfa\": 75000,\n    \"total_outstanding_debt\": 0,\n    \"created_at\": \"2026-04-28T15:00:00.000000Z\"\n  },\n  \"message\": \"Farmer created successfully.\"\n}"
            },
            {
              "name": "422 Validation Error",
              "status": "Unprocessable Content",
              "code": 422,
              "body": "{\n  \"success\": false,\n  \"message\": \"Validation failed.\",\n  \"errors\": {\n    \"identifier\": [\"The identifier has already been taken.\"],\n    \"phone_number\": [\"The phone number has already been taken.\"]\n  }\n}"
            }
          ]
        }
      ]
    },

    {
      "name": "Transactions",
      "item": [
        {
          "name": "Create Transaction — Cash",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/api/transactions", "host": ["{{base_url}}"], "path": ["api", "transactions"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"farmer_id\": 3,\n  \"payment_method\": \"cash\",\n  \"items\": [\n    { \"product_id\": 1, \"quantity\": 2 },\n    { \"product_id\": 10, \"quantity\": 1 }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Cash transaction — no interest, no debt created. `items` array requires at least one entry."
          },
          "response": [
            {
              "name": "201 Created — Cash",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"id\": 7,\n    \"farmer\": { \"id\": 3, \"identifier\": \"CI-2024-003\", \"firstname\": \"Koffi\", \"lastname\": \"Assouman\" },\n    \"operator\": { \"id\": 4, \"name\": \"Amara Operator\" },\n    \"items\": [\n      { \"product_id\": 1, \"product_name\": \"Roundup 1L\", \"quantity\": 2, \"unit_price_fcfa\": 8500, \"subtotal_fcfa\": 17000 },\n      { \"product_id\": 10, \"product_name\": \"NPK 15-15-15 25kg\", \"quantity\": 1, \"unit_price_fcfa\": 18000, \"subtotal_fcfa\": 18000 }\n    ],\n    \"total_fcfa\": 35000,\n    \"payment_method\": \"cash\",\n    \"interest_rate\": null,\n    \"interest_amount_fcfa\": null,\n    \"debt\": null,\n    \"created_at\": \"2026-04-28T15:00:00.000000Z\"\n  },\n  \"message\": \"Transaction completed successfully.\"\n}"
            }
          ]
        },
        {
          "name": "Create Transaction — Credit",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/api/transactions", "host": ["{{base_url}}"], "path": ["api", "transactions"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"farmer_id\": 5,\n  \"payment_method\": \"credit\",\n  \"interest_rate\": 0.15,\n  \"items\": [\n    { \"product_id\": 19, \"quantity\": 4 },\n    { \"product_id\": 13, \"quantity\": 2 }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Credit transaction — `interest_rate` is required (0.0 to 1.0). A debt record is created automatically. Returns 422 if farmer's credit limit would be exceeded."
          },
          "response": [
            {
              "name": "201 Created — Credit with debt",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"id\": 8,\n    \"farmer\": { \"id\": 5, \"identifier\": \"CI-2024-005\", \"firstname\": \"Yao\", \"lastname\": \"N'Goran\" },\n    \"operator\": { \"id\": 4, \"name\": \"Amara Operator\" },\n    \"items\": [\n      { \"product_id\": 19, \"product_name\": \"Semence Maïs IKENNE 5kg\", \"quantity\": 4, \"unit_price_fcfa\": 6500, \"subtotal_fcfa\": 26000 },\n      { \"product_id\": 13, \"product_name\": \"Urée 46% 25kg\", \"quantity\": 2, \"unit_price_fcfa\": 16500, \"subtotal_fcfa\": 33000 }\n    ],\n    \"total_fcfa\": 67850,\n    \"payment_method\": \"credit\",\n    \"interest_rate\": \"0.1500\",\n    \"interest_amount_fcfa\": 8850,\n    \"debt\": {\n      \"id\": 4,\n      \"amount_fcfa\": 67850,\n      \"remaining_fcfa\": 67850,\n      \"status\": \"open\"\n    },\n    \"created_at\": \"2026-04-28T15:00:00.000000Z\"\n  },\n  \"message\": \"Transaction completed successfully.\"\n}"
            },
            {
              "name": "422 — Credit limit exceeded",
              "status": "Unprocessable Content",
              "code": 422,
