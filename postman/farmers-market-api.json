              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"id\": 7,\n    \"name\": \"Kone Supervisor\",\n    \"email\": \"kone.supervisor@xpertbot.com\",\n    \"role\": \"supervisor\",\n    \"created_by\": 1,\n    \"created_at\": \"2026-04-28T15:00:00.000000Z\"\n  },\n  \"message\": \"Supervisor created successfully.\"\n}"
