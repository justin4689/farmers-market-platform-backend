              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": [\n    {\n      \"id\": 1,\n      \"name\": \"Pesticides\",\n      \"parent_id\": null,\n      \"children\": [\n        { \"id\": 2, \"name\": \"Herbicides\",   \"parent_id\": 1, \"children\": [] },\n        { \"id\": 3, \"name\": \"Insecticides\", \"parent_id\": 1, \"children\": [] },\n        { \"id\": 4, \"name\": \"Fongicides\",   \"parent_id\": 1, \"children\": [] }\n      ]\n    },\n    {\n      \"id\": 5,\n      \"name\": \"Engrais\",\n      \"parent_id\": null,\n      \"children\": [\n        { \"id\": 6, \"name\": \"NPK\",               \"parent_id\": 5, \"children\": [] },\n        { \"id\": 7, \"name\": \"Urée\",              \"parent_id\": 5, \"children\": [] },\n        { \"id\": 8, \"name\": \"Engrais organiques\", \"parent_id\": 5, \"children\": [] }\n      ]\n    }\n  ],\n  \"message\": \"Categories retrieved successfully.\"\n}"
            }
